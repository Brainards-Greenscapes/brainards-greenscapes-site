<footer id="cs-footer-079">
  <a href="/" class="cs-logo-badge" aria-label="{{ site.name }} home">
    <img alt="" decoding="async" src="/assets/images/logo-circle-216.webp" height="216" width="216" loading="lazy">
  </a>
  <div class="cs-watermark-wrap" aria-hidden="true">
    <span class="cs-watermark">Brainard's</span>
  </div>

  <div class="cs-container">
    <div class="cs-footer-top">

      <div class="cs-about">
        <p class="cs-text">Brainard's Greenscapes transforms Las Cruces yards with water-wise landscape design, custom hardscaping, and year-round maintenance built for the New Mexico climate.</p>
        <ul class="cs-social" aria-label="social media links">
          <li class="cs-social-item">
            <a href="{{ site.social.facebook }}" class="cs-social-link" aria-label="Visit us on Facebook" rel="noopener" target="_blank">
              <img src="/assets/svgs/facebook.svg" alt="" width="12" height="12" aria-hidden="true" loading="lazy" decoding="async">
            </a>
          </li>
          <li class="cs-social-item">
            <a href="{{ site.social.instagram }}" class="cs-social-link" aria-label="Visit us on Instagram" rel="noopener" target="_blank">
              <img src="/assets/svgs/instagram.svg" alt="" width="12" height="12" aria-hidden="true" loading="lazy" decoding="async">
            </a>
          </li>
          <li class="cs-social-item">
            <a href="{{ site.social.linkedin }}" class="cs-social-link" aria-label="Visit us on LinkedIn" rel="noopener" target="_blank">
              <img src="/assets/svgs/linkedin.svg" alt="" width="12" height="12" aria-hidden="true" loading="lazy" decoding="async">
            </a>
          </li>
        </ul>
      </div>

      <nav aria-label="services" class="cs-links cs-links-services">
        <h2 class="cs-col-heading">Services</h2>
        <ul class="cs-links-stack">
          <li><a href="/services/landscape-design/" class="cs-link">Landscape Design</a></li>
          <li><a href="/services/landscaping/" class="cs-link">Landscaping</a></li>
          <li><a href="/services/hardscaping/" class="cs-link">Hardscaping</a></li>
          <li><a href="/services/irrigation/" class="cs-link">Irrigation &amp; Sprinklers</a></li>
          <li><a href="/services/landscape-maintenance/" class="cs-link">Landscape Maintenance</a></li>
          <li><a href="/services/" class="cs-link cs-link-strong">View All Services →</a></li>
        </ul>
      </nav>

      <nav aria-label="service areas" class="cs-links cs-links-areas">
        <h2 class="cs-col-heading">Areas We Serve</h2>
        <ul class="cs-links-stack">
          <li><a href="/service-areas/las-cruces-nm/" class="cs-link">Las Cruces, NM</a></li>
          <li><a href="/service-areas/mesilla-nm/" class="cs-link">Mesilla, NM</a></li>
          <li><a href="/service-areas/dona-ana-nm/" class="cs-link">Doña Ana, NM</a></li>
          <li><a href="/service-areas/sonoma-ranch-nm/" class="cs-link">Sonoma Ranch</a></li>
          <li><a href="/service-areas/picacho-hills-nm/" class="cs-link">Picacho Hills</a></li>
          <li><a href="/service-areas/east-mesa-nm/" class="cs-link">East Mesa</a></li>
          <li><a href="/service-areas/anthony-nm/" class="cs-link">Anthony, NM</a></li>
          <li><a href="/service-areas/sunland-park-nm/" class="cs-link">Sunland Park, NM</a></li>
          <li><a href="/service-areas/" class="cs-link cs-link-strong">View All Service Areas →</a></li>
        </ul>
      </nav>

      <div class="cs-contact">
        <h2 class="cs-col-heading">Contact Information</h2>
        <ul class="cs-contact-list">
          <li class="cs-contact-item">
            <img src="/assets/svgs/clock.svg" alt="" width="20" height="20" aria-hidden="true" class="cs-contact-icon" loading="lazy" decoding="async">
            <span>{{ site.hours }}</span>
          </li>
          <li class="cs-contact-item">
            <img src="/assets/svgs/phone.svg" alt="" width="20" height="20" aria-hidden="true" class="cs-contact-icon" loading="lazy" decoding="async">
            <a href="tel:{{ site.phoneRaw | replace('-', '') }}" class="cs-contact-link">{{ site.phone }}</a>
          </li>
          <li class="cs-contact-item">
            <img src="/assets/svgs/message.svg" alt="" width="20" height="20" aria-hidden="true" class="cs-contact-icon" loading="lazy" decoding="async">
            <a href="mailto:{{ site.email }}" class="cs-contact-link">{{ site.email }}</a>
          </li>
        </ul>
        <a href="/contact/" class="cs-button-solid">Free Estimate</a>
      </div>

    </div>

    <div class="cs-footer-bottom">
      <p class="cs-copyright">© Copyright {{ year }} — {{ site.name }}</p>
      <ul class="cs-legal" aria-label="legal links">
        <li><a href="/privacy/" class="cs-legal-link">Privacy Policy</a></li>
        <li class="cs-legal-sep" aria-hidden="true">|</li>
        <li><a href="/terms/" class="cs-legal-link">Terms of Use</a></li>
      </ul>
    </div>
  </div>
</footer>
