---
layout: layouts/base.njk
title: "Contact Brainard's Greenscapes | Free Estimate Las Cruces"
description: "Get a free on-site estimate for your landscaping project in Las Cruces, NM. Call (575) 635-8883 or fill out our contact form."
---

<section id="contact-500" style="padding-top: clamp(10rem, 18vw, 15rem);">
  <img class="cs-leaf cs-leaf-left cs-hide-on-mobile" src="/assets/svgs/fern.svg" alt="" width="224" height="224" loading="lazy" decoding="async">
  <img class="cs-leaf cs-leaf-right cs-hide-on-mobile" src="/assets/svgs/fern.svg" alt="" width="224" height="224" loading="lazy" decoding="async">
  <div class="cs-container">
    <div class="cs-header">
      <span class="cs-topper">
        <span class="cs-topper-dot"></span>
        <img class="cs-topper-arrow" src="/assets/svgs/arrow-right.svg" alt="" width="48" height="8" loading="lazy" decoding="async">
        Contact
      </span>
      <h1 class="cs-title">Get Your Free Estimate</h1>
      <p class="cs-text">Tell us about your project and we'll schedule a free on-site walkthrough. Most estimates are delivered within a few business days.</p>
    </div>
    <div class="cs-layout">
      <div class="cs-info-card">
        <div class="cs-info-picture">
          <img src="/assets/images/brainards-pavers-1-cfa6a793.jpeg" alt="Paver walkway with stone retaining wall side yard by Brainard's Greenscapes" width="506" height="850" loading="lazy" decoding="async">
        </div>
        <div class="cs-info-body">
          <h2 class="cs-info-heading">Contact</h2>
          <ul class="cs-info-list">
            <li class="cs-info-item">
              <span class="cs-info-label">Email</span>
              <a href="mailto:{{ site.email }}" class="cs-info-value">{{ site.email }}</a>
            </li>
            <li class="cs-info-item">
              <span class="cs-info-label">Phone</span>
              <a href="tel:{{ site.phoneRaw }}" class="cs-info-value">{{ site.phone }}</a>
            </li>
            <li class="cs-info-item">
              <span class="cs-info-label">Address</span>
              <a href="{{ site.googleMapsUrl }}" class="cs-info-value" target="_blank" rel="noopener">{{ site.address.full }}</a>
            </li>
            <li class="cs-info-item">
              <span class="cs-info-label">Hours</span>
              <span class="cs-info-value">{{ site.hours }}</span>
            </li>
          </ul>
          <h3 class="cs-info-heading cs-info-heading-social">Find Us On</h3>
          <ul class="cs-social-list">
            <li>
              <a href="{{ site.social.facebook }}" class="cs-social-link" aria-label="Facebook" target="_blank" rel="noopener">
                <img src="/assets/svgs/facebook.svg" alt="" width="12" height="12" loading="lazy" decoding="async">
              </a>
            </li>
            <li>
              <a href="{{ site.social.instagram }}" class="cs-social-link" aria-label="Instagram" target="_blank" rel="noopener">
                <img src="/assets/svgs/instagram.svg" alt="" width="12" height="12" loading="lazy" decoding="async">
              </a>
            </li>
            <li>
              <a href="{{ site.social.linkedin }}" class="cs-social-link" aria-label="LinkedIn" target="_blank" rel="noopener">
                <img src="/assets/svgs/linkedin.svg" alt="" width="12" height="12" loading="lazy" decoding="async">
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="cs-form-wrapper">
        <form class="cs-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <p class="cs-honeypot">
            <label>Don't fill this out: <input name="bot-field"></label>
          </p>
          <span class="cs-form-topper">Contact</span>
          <h2 class="cs-form-title">Get in Touch</h2>
          <div class="cs-row">
            <label class="cs-label">
              Name <span class="cs-required">*</span>
              <input class="cs-input" type="text" name="name" required placeholder="Full name">
            </label>
            <label class="cs-label">
              Email <span class="cs-required">*</span>
              <input class="cs-input" type="email" name="email" required placeholder="Email address">
            </label>
          </div>
          <div class="cs-row">
            <label class="cs-label">
              Phone
              <input class="cs-input" type="tel" name="phone" placeholder="Phone number">
            </label>
            <label class="cs-label">
              How Did You Find Us?
              <input class="cs-input" type="text" name="referral" placeholder="Google, referral, etc.">
            </label>
          </div>
          <fieldset class="cs-services">
            <legend>What Services Are You Interested In? <span class="cs-required">*</span></legend>
            <div class="cs-services-grid">
              {%- for service in services %}
              <label class="cs-check">
                <input type="checkbox" name="services" value="{{ service.title }}">
                {{ service.title }}
              </label>
              {%- endfor %}
            </div>
          </fieldset>
          <label class="cs-label">
            Message <span class="cs-required">*</span>
            <textarea class="cs-textarea" name="message" required placeholder="Tell us about your project..."></textarea>
          </label>
          <button type="submit" class="cs-submit">Submit</button>
        </form>
      </div>
    </div>
  </div>
</section>

<section id="service-areas-825">
  <img class="cs-fern cs-hide-on-mobile" src="/assets/svgs/fern.svg" alt="" width="220" height="220" loading="lazy" decoding="async">
  <div class="cs-container">
    <div class="cs-info-card">
      <div class="cs-info-head">
        <span class="cs-topper">
          <span class="cs-topper-dot"></span>
          <img class="cs-topper-arrow" src="/assets/svgs/arrow-right.svg" alt="" width="48" height="8" loading="lazy" decoding="async">
          Service Areas
        </span>
        <h2 class="cs-title">Las Cruces Metro Area</h2>
      </div>
      <div class="cs-info-body">
        <p class="cs-text">We proudly serve homeowners and commercial properties across the greater Las Cruces, NM region.</p>
        <ul class="cs-locations">
          <li><a href="/service-areas/las-cruces-nm/">Las Cruces</a></li>
          <li><a href="/service-areas/mesilla-nm/">Mesilla</a></li>
          <li><a href="/service-areas/dona-ana-nm/">Doña Ana</a></li>
          <li><a href="/service-areas/organ-nm/">Organ</a></li>
          <li><a href="/service-areas/anthony-nm/">Anthony</a></li>
          <li><a href="/service-areas/sunland-park-nm/">Sunland Park</a></li>
        </ul>
      </div>
      <div class="cs-info-picture">
        <img src="/assets/images/brainards-xeriscaping-7-b2301eed.jpeg" alt="Desert landscape project in Las Cruces" width="800" height="130" loading="lazy" decoding="async">
      </div>
    </div>
    <div class="cs-map">
      <iframe src="{{ site.googleMapsEmbed }}" title="Map of Las Cruces, NM service area" width="600" height="450" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
    </div>
  </div>
</section>

<section id="lets-talk-318">
  <div class="cs-container">
    <h2 class="cs-title">Let's Talk About Your Landscape</h2>
    <a href="tel:{{ site.phoneRaw }}" class="cs-talk-button">Call {{ site.phone }}</a>
  </div>
  <img class="cs-tree" src="/assets/svgs/talk-tree.svg" alt="" loading="lazy" decoding="async">
  <img class="cs-bird cs-bird-1" src="/assets/svgs/talk-bird-1.svg" alt="" loading="lazy" decoding="async">
  <img class="cs-bird cs-bird-2" src="/assets/svgs/talk-bird-2.svg" alt="" loading="lazy" decoding="async">
  <img class="cs-bird cs-bird-3" src="/assets/svgs/talk-bird-3.svg" alt="" loading="lazy" decoding="async">
  <img class="cs-grass" src="/assets/svgs/talk-grass-top.svg" alt="" loading="lazy" decoding="async">
</section>
